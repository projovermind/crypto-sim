generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === Shared: CryptoSim + Teledit (동일 DB 공유 — 양쪽 스키마 반드시 동기화!) ===
model User {
  id        String     @id @default(cuid())
  email     String     @unique  // 아이디 (username)로 사용
  name      String
  nickname1 String?
  nickname2 String?
  entryWaitWord   String?   // 진입 대기 단어
  profitProofWord String?   // 수익 인증 단어
  password  String
  role              String     @default("USER")    // "USER" | "MANAGER" | "ADMIN"
  status            String     @default("PENDING")  // "PENDING" | "APPROVED" | "SUSPENDED"
  teledditTemplate      String?    // Teledit 메시지 템플릿
  teledditLongTemplate  String?    // 롱 포지션 전용 템플릿
  teledditShortTemplate String?    // 숏 포지션 전용 템플릿
  // TODO: Teledit DB 공유 중 — 아래 필드 추가 시 Teledit 스키마와 반드시 동기화 후 prisma db push
  teleditApiUrl        String?    // Teledit 서버 URL
  teleditEmail         String?    // Teledit 로그인 이메일
  teleditPassword      String?    // Teledit 로그인 비밀번호 (평문 저장)
  teleditCloseTemplate  String?    // 청산 메시지 템플릿
  teleditProfitTemplate String?    // 수익 인증 메시지 템플릿
  // --- 포지션 진입/종료 타이밍 템플릿 (Teledit 동기화 필수) ---
  // 추가 필드: teleditPreEntryTemplate, teleditPostEntry1Template, teleditPostEntry2Template,
  //   teleditPostEntry3Template, teleditPreCloseTemplate, teleditPostClose1Template,
  //   teleditPostClose2Template, teleditPostClose3Template
  teleditPreEntryTemplate   String?    // 진입 N~N1분 전
  teleditPostEntry1Template String?    // 진입 N분 후 1
  teleditPostEntry2Template String?    // 진입 N분 후 2
  teleditPostEntry3Template String?    // 진입 N분 후 3
  teleditPreCloseTemplate   String?    // 종료 N~N1분 전
  teleditPostClose1Template String?    // 종료 N분 후 1
  teleditPostClose2Template String?    // 종료 N분 후 2
  teleditPostClose3Template String?    // 종료 N분 후 3
  // --- 활성화 토글 (각 템플릿별 on/off) ---
  teledditEnabled          Boolean    @default(true)  // 진입 메시지 활성화
  teledditLongEnabled      Boolean    @default(true)  // 롱 전용 템플릿 활성화
  teledditShortEnabled     Boolean    @default(true)  // 숏 전용 템플릿 활성화
  teleditPreEntryEnabled   Boolean    @default(true)  // 진입 전 알림 활성화
  teleditPostEntry1Enabled Boolean    @default(true)  // 진입 후 1 활성화
  teleditPostEntry2Enabled Boolean    @default(true)  // 진입 후 2 활성화
  teleditPostEntry3Enabled Boolean    @default(true)  // 진입 후 3 활성화
  teleditCloseEnabled      Boolean    @default(true)  // 청산 메시지 활성화
  teleditPreCloseEnabled   Boolean    @default(true)  // 종료 전 알림 활성화
  teleditPostClose1Enabled Boolean    @default(true)  // 종료 후 1 활성화
  teleditPostClose2Enabled Boolean    @default(true)  // 종료 후 2 활성화
  teleditPostClose3Enabled Boolean    @default(true)  // 종료 후 3 활성화
  teleditProfitEnabled     Boolean    @default(true)  // 수익 인증 활성화
  preEntryMinSec    Int        @default(60)   // 진입 전 알림 최소(초)
  preEntryMaxSec    Int        @default(120)  // 진입 전 알림 최대(초)
  preCloseMinSec    Int        @default(60)   // 종료 전 알림 최소(초)
  preCloseMaxSec    Int        @default(120)  // 종료 전 알림 최대(초)
  // --- 진입 후 단일 메시지 (PostEntry 7개 메시지 구조) ---
  teleditPostEntryTemplate  String?    // 진입 후 메시지 템플릿
  teleditPostEntryEnabled   Boolean    @default(true)  // 진입 후 메시지 활성화
  postEntryMinSec           Int        @default(30)   // 진입 후 메시지 최소(초)
  postEntryMaxSec           Int        @default(60)   // 진입 후 메시지 최대(초)
  // --- 수익 인증 2번째 메시지 ---
  teleditProfitTemplate2    String?    // 수익 인증 2 템플릿
  teleditProfit2Enabled     Boolean    @default(true)  // 수익 인증 2 활성화
  profit1MinSec             Int        @default(30)   // 수익 인증 1 최소(초)
  profit1MaxSec             Int        @default(60)   // 수익 인증 1 최대(초)
  profit2MinSec             Int        @default(30)   // 수익 인증 2 최소(초)
  profit2MaxSec             Int        @default(60)   // 수익 인증 2 최대(초)
  varRoundEnabled           Boolean    @default(false) // 변수 반올림 활성화
  varRoundDecimals          Int        @default(2)    // 변수 반올림 소수점 자릿수
  preEntryCommentMin        Int        @default(12)
  preEntryCommentMax        Int        @default(31)
  longCommentMin            Int        @default(0)
  longCommentMax            Int        @default(2)
  shortCommentMin           Int        @default(0)
  shortCommentMax           Int        @default(2)
  postEntryCommentMin       Int        @default(8)
  postEntryCommentMax       Int        @default(32)
  preCloseCommentMin        Int        @default(0)
  preCloseCommentMax        Int        @default(3)
  closeCommentMin           Int        @default(5)
  closeCommentMax           Int        @default(14)
  profit1CommentMin         Int        @default(8)
  profit1CommentMax         Int        @default(23)
  profit2CommentMin         Int        @default(16)
  profit2CommentMax         Int        @default(42)
  channelName      String?    // 채널명
  channelAvatarUrl String?    // 채널 아바타 URL
  createdAt         DateTime   @default(now())
  positions         Position[]
  telegramAccount   TelegramAccount?
  telegramChannels  TelegramChannel[]
  messageOverrides  MessageOverride[]
}

model Position {
  id             String   @id @default(cuid())
  positionNumber Int      @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String   // e.g. "BTCUSDT"
  side        String   // "LONG" or "SHORT"
  leverage    Int      // 1, 2, 5, 10, 25, 50, 100, 125
  entryPrice  Float
  inputPrice  Float?   // 사용자가 입력한 원래 가격 (슬리피지 적용 전)
  amount      Float    // Position size in USDT
  quantity    Float    // Coin quantity (amount / entryPrice)
  marginMode  String   @default("CROSS") // "CROSS" or "ISOLATED"
  orderType   String   @default("MARKET") // "MARKET" or "LIMIT"
  entryFee    Float    @default(0) // Opening fee in USDT
  takeProfit  Float?   // TP price
  stopLoss    Float?   // SL price
  status      String   @default("OPEN") // "OPEN", "CLOSED_TP", "CLOSED_SL", "CLOSED_MANUAL"
  closedAt    DateTime?
  closedPrice Float?
  pnl         Float?
  shareImageUrl String?  // Vercel Blob URL — html-to-image로 생성된 profit card
  entryTime   DateTime
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  overrides            MessageOverride[]
  positionComments     PositionComment[]
  positionCommentAuthors PositionCommentAuthor[]
  positionCommentCount   PositionCommentCount?
}

model PositionCommentCount {
  id             String   @id @default(cuid())
  positionId     String   @unique
  position       Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  preEntryCount  Int
  longCount      Int
  shortCount     Int
  postEntryCount Int
  preCloseCount  Int
  closeCount     Int
  profit1Count   Int
  profit2Count   Int
  createdAt      DateTime @default(now())
}

// === Teledit 전용 모델 (DB 공유로 인해 CryptoSim에도 선언 필수) ===
model TelegramConfig {
  id        String   @id @default(cuid())
  apiId     String
  apiHash   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone           String
  sessionString   String   @db.Text
  firstName       String?
  lastName        String?
  username        String?
  telegramUserId  BigInt?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TelegramChannel {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramId      BigInt   @unique
  title           String
  type            String   @default("channel")
  avatarUrl       String?
  memberCount     Int      @default(0)
  isMonitoring    Boolean  @default(true)
  lastFetchedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  messages        TelegramMessage[]
}

model TelegramMessage {
  id              String   @id @default(cuid())
  channelId       String
  channel         TelegramChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  telegramMsgId   Int
  senderName      String
  senderAvatar    String?
  content         String   @db.Text
  mediaUrl        String?
  mediaType       String?
  replyToMsgId    Int?
  viewCount       Int      @default(0)
  sentAt          DateTime
  createdAt       DateTime @default(now())
  override        MessageOverride?

  @@unique([channelId, telegramMsgId])
  @@index([channelId, sentAt])
}

model MessageOverride {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId       String?  @unique
  message         TelegramMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  positionId      String?
  position        Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  type            String
  channelId       String?
  content         String   @db.Text
  senderName      String?
  views           Int?
  insertAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CommentPool {
  id        String   @id @default(cuid())
  type      String   // 'preEntry'|'long'|'short'|'postEntry'|'preClose'|'close'|'profit1'|'profit2'
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model CommentAuthorPool {
  id        String   @id @default(cuid())
  name      String
  avatarUrl String?
  nickname1 String?
  nickname2 String?
  createdAt DateTime @default(now())
}

model PositionComment {
  id          String    @id @default(cuid())
  positionId  String
  position    Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  messageType String
  authorName  String
  avatarUrl   String?
  nickname1   String?
  nickname2   String?
  content     String    @db.Text
  orderIndex  Int
  createdAt   DateTime  @default(now())

  @@index([positionId, messageType])
}

model PositionCommentAuthor {
  id         String    @id @default(cuid())
  positionId String
  position   Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  authorName String
  avatarUrl  String?
  nickname1  String?
  nickname2  String?
  createdAt  DateTime  @default(now())

  @@index([positionId])
}
